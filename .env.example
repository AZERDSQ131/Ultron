NVIDIA_API_KEY=
NEMOTRON_MODEL=z-ai/glm-5.2
NEMOTRON_BASE_URL=https://integrate.api.nvidia.com/v1

CONTEXT_WINDOW_TOKENS=262144
WEB_PORT=4173
DATABASE_PATH=ultron-state.sqlite3

# Web search: auto uses Tavily when a key is available, otherwise DuckDuckGo.
WEB_SEARCH_PROVIDER=auto
TAVILY_API_KEY=

# /computer-use (CLI-only): a separate model from NEMOTRON_MODEL, dedicated to
# reading the macOS accessibility tree and calling one tool per step to drive
# the real UI (native/computer-use/main.swift) — no vision needed. Not
# deepseek-ai/deepseek-v4-flash: it reliably degenerates on the 2nd
# tool-calling turn on this NVIDIA endpoint (see src/config.ts).
COMPUTER_USE_MODEL=meta/llama-3.2-90b-vision-instruct
COMPUTER_USE_MAX_STEPS=30
