NVIDIA_API_KEY=
NEMOTRON_MODEL=deepseek-ai/deepseek-v4-flash
NEMOTRON_BASE_URL=https://integrate.api.nvidia.com/v1

# Which chat-completion provider is active at startup — "nvidia" (default)
# or "deepseek". Switchable at runtime via /provider (CLI, web, Telegram);
# this only sets the initial value. NVIDIA_API_KEY is still required either
# way, since photo analysis (HEALTH_VISION_MODEL below) always runs on
# NVIDIA regardless of which chat provider is active.
LLM_PROVIDER=nvidia

# DeepSeek's own API (not NVIDIA-hosted) — a second chat-completion
# provider, selected via LLM_PROVIDER/the /provider command. Only required
# if you actually switch to it.
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Vision-capable model used only for meal/exercise photo analysis (see
# src/core/health/visionAnalyzer.ts) — the main chat model above is
# text-only.
HEALTH_VISION_MODEL=nvidia/nemotron-nano-12b-v2-vl

# Only required to run the Telegram interface (pnpm telegram / start:telegram).
TELEGRAM_BOT_TOKEN=

CONTEXT_WINDOW_TOKENS=262144
WEB_PORT=4173
DATABASE_PATH=ultron-state.sqlite3

# Per-turn cost shown in the /verbose stats line (model | in | out | time |
# $cost). NVIDIA NIM doesn't publish per-token pricing the way Anthropic/
# OpenAI do, so this is an estimate you can tune, not a billed figure.
NEMOTRON_PRICE_IN_PER_M=0.2
NEMOTRON_PRICE_OUT_PER_M=0.6

# Web search: auto uses Tavily when a key is available, otherwise DuckDuckGo.
WEB_SEARCH_PROVIDER=auto
TAVILY_API_KEY=

# Only required by the remote CLI (pnpm remote / start:remote / the `ultron`
# bin once linked) — the address of a ULTRON web server to connect to over
# HTTP/SSE instead of running the graph in-process. Nothing else above is
# needed on a machine that only runs this client (see src/interfaces/cli/remote.ts).
ULTRON_SERVER_URL=

# Shared secret checked against the "x-health-token" header on
# POST /api/health-data/ingest — the only route on the web server that
# requires auth, since it's meant to be called directly by an external
# health-export app/shortcut rather than from the browser UI. Required for
# that endpoint to accept requests; leave unset to disable it entirely.
HEALTH_INGEST_TOKEN=

# SSH alias (from ~/.ssh/config, on the machine ULTRON's own process runs
# on) used by run_shell_command/read_file/write_file/edit_file/
# list_directory/search_files when called with host: "mac", and by
# open_app/applescript_run whenever ULTRON isn't itself running on macOS.
# Defaults to "mac" — only set this if your SSH config uses a different
# alias for the Mac.
MAC_SSH_HOST=mac
