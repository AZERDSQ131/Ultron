{
  "name": "ultron",
  "version": "0.1.0",
  "description": "Agent IA personnel — boucle conversationnelle + memoire persistante",
  "type": "module",
  "private": true,
  "main": "dist/interfaces/cli/index.js",
  "bin": {
    "ultron": "dist/interfaces/cli/remote.js"
  },
  "scripts": {
    "dev": "tsx src/interfaces/cli/index.ts",
    "remote": "tsx src/interfaces/cli/remote.ts",
    "web": "tsx src/interfaces/web/server.ts",
    "telegram": "tsx src/interfaces/telegram/index.ts",
    "build": "tsc -p tsconfig.json && cp -r src/interfaces/web/public dist/interfaces/web/public && cp src/interfaces/cli/ascii-art.txt dist/interfaces/cli/ascii-art.txt",
    "start": "node dist/interfaces/cli/index.js",
    "start:remote": "node dist/interfaces/cli/remote.js",
    "start:web": "node dist/interfaces/web/server.js",
    "start:telegram": "node dist/interfaces/telegram/index.js",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test tests/**/*.test.ts"
  },
  "dependencies": {
    "@langchain/core": "^0.3.40",
    "@langchain/langgraph": "^0.2.60",
    "@langchain/langgraph-checkpoint": "0.0.18",
    "@langchain/openai": "^0.4.4",
    "chalk": "^5.6.2",
    "dotenv": "^16.4.7",
    "grammy": "^1.45.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.13.1",
    "@types/pg": "^8.11.11",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  },
  "packageManager": "pnpm@9.15.4"
}
