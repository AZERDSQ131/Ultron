{
  "name": "ultron",
  "version": "0.1.0",
  "description": "Agent IA personnel — boucle conversationnelle + memoire persistante",
  "type": "module",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx src/index.ts",
    "web": "tsx src/web/server.ts",
    "build": "tsc -p tsconfig.json && cp -r src/web/public dist/web/public",
    "start": "node dist/index.js",
    "start:web": "node dist/web/server.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@langchain/core": "^0.3.40",
    "@langchain/langgraph": "^0.2.60",
    "@langchain/openai": "^0.4.4",
    "chalk": "^5.6.2",
    "dotenv": "^16.4.7",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.13.1",
    "@types/pg": "^8.11.11",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  },
  "packageManager": "pnpm@9.15.4"
}
